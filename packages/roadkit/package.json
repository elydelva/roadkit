{
  "name": "roadkit",
  "version": "1.0.0",
  "description": "Decision-first, agent-native project management system for git repositories",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elydelva/roadkit.git"
  },
  "keywords": [
    "adr",
    "architecture",
    "decision-record",
    "cli",
    "agent",
    "git"
  ],
  "bin": {
    "rkit": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist && rm -f tsconfig.tsbuildinfo",
    "prepublishOnly": "bun run typecheck && bun run build && bun test"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@roadkit/core": "workspace:*",
    "@roadkit/fs": "workspace:*",
    "@roadkit/git": "workspace:*",
    "@roadkit/lint": "workspace:*",
    "@roadkit/tui": "workspace:*",
    "@roadkit/sync": "workspace:*",
    "commander": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
