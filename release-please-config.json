{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "perf", "section": "Performance Improvements" },
    { "type": "deps", "section": "Dependencies" },
    { "type": "revert", "section": "Reverts" },
    { "type": "docs", "section": "Documentation", "hidden": false },
    { "type": "chore", "section": "Miscellaneous", "hidden": true },
    { "type": "refactor", "section": "Code Refactoring", "hidden": true },
    { "type": "test", "section": "Tests", "hidden": true },
    { "type": "ci", "section": "CI/CD", "hidden": true }
  ],
  "packages": {
    "packages/core": { "release-type": "node", "component": "core" },
    "packages/fs": { "release-type": "node", "component": "fs" },
    "packages/git": { "release-type": "node", "component": "git" },
    "packages/lint": { "release-type": "node", "component": "lint" },
    "packages/tui": { "release-type": "node", "component": "tui" },
    "packages/sync": { "release-type": "node", "component": "sync" },
    "packages/roadkit": { "release-type": "node", "component": "roadkit" }
  },
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "roadkit",
      "components": ["core", "fs", "git", "lint", "tui", "sync", "roadkit"]
    }
  ]
}
