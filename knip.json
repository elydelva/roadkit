{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    ".": {
      "entry": [],
      "project": ["packages/*/src/**/*.ts"]
    },
    "packages/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "ignore": ["src/**/*.test.ts", "src/**/*.spec.ts"]
    }
  },
  "ignoreDependencies": [
    "bun-types",
    "typescript",
    "@roadkit/core",
    "@roadkit/fs",
    "@roadkit/git",
    "@roadkit/lint",
    "@roadkit/tui",
    "@roadkit/sync",
    "commander",
    "gray-matter",
    "js-yaml",
    "ink",
    "react",
    "@types/react"
  ],
  "ignoreExportsUsedInFile": true
}
